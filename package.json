{
  "name": "boring-agent-framework",
  "version": "0.0.0",
  "description": "Boring, explicit TypeScript primitives for LLM-powered programs.",
  "homepage": "https://github.com/wimpheling/boring-agent-framework#readme",
  "bugs": {
    "url": "https://github.com/wimpheling/boring-agent-framework/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wimpheling/boring-agent-framework.git",
    "directory": "baf-vp-create"
  },
  "files": [
    "dist"
  ],
  "type": "module",
